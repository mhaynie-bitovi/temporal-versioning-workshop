#!/bin/bash
set -euo pipefail

# Wait for Instruqt bootstrap to complete
until [ -f /opt/instruqt/bootstrap/host-bootstrap-completed ]; do
    sleep 1
done

# ── System packages ──────────────────────────────────────────────────────────
apt-get update -qq
apt-get install -y -qq python3 python3-pip python3-venv git make curl > /dev/null

# ── Temporal CLI ─────────────────────────────────────────────────────────────
curl -sSf https://temporal.download/cli.sh | sh -s -- --version 1.6.2
export PATH="$HOME/.temporalio/bin:$PATH"
echo 'export PATH="$HOME/.temporalio/bin:$PATH"' >> /root/.bashrc

# ── Clone the workshop repo ─────────────────────────────────────────────────
git clone https://github.com/mhaynie-bitovi/temporal-versioning-workshop.git /root/temporal-versioning-workshop

# ── Python virtual environment ───────────────────────────────────────────────
cd /root/temporal-versioning-workshop
python3 -m venv env
env/bin/pip install -q -r requirements.txt

# ── Start Temporal dev server (background) ───────────────────────────────────
nohup temporal server start-dev --ip 0.0.0.0 > /tmp/temporal-server.log 2>&1 &

# Wait for Temporal to be ready
echo "Waiting for Temporal server..."
for i in $(seq 1 60); do
    if temporal workflow list --namespace default --address 127.0.0.1:7233 2>/dev/null | head -n1 > /dev/null 2>&1; then
        echo "Temporal server is ready."
        break
    fi
    sleep 1
done

# ── Set default working directory ────────────────────────────────────────────
echo 'cd /root/temporal-versioning-workshop/exercises/2-worker-versioning/practice' >> /root/.bashrc
echo 'source /root/temporal-versioning-workshop/env/bin/activate' >> /root/.bashrc
